# Canadian Solar (CSI) Smart Energy API
# Production Chinese/International cluster — confirmed via auth probe 2026-05-07.
# (CSI also documents an EMEA prod URL https://sep-api-eu.csisolar.com and a
# sandbox at https://csiapi.hxsoft.net:9016 — both rejected our credentials,
# the sandbox is also unreachable from PK + US.)
CSI_API_URL=https://sep-api.csisolar.com
CSI_APP_ID=xxx
CSI_APP_SECRET=xxx

# App
NEXT_PUBLIC_APP_URL=https://solar.bijlibachao.pk
NODE_ENV=development

# Sentry — error + performance monitoring (https://sentry.io)
